#!/usr/bin/env bash
set -euo pipefail

WT_FREE_PREFIX="${WT_FREE_PREFIX:-free-}"
WT_REPO_RAW_BASE="${WT_REPO_RAW_BASE:-https://raw.githubusercontent.com/tomergalatwix/wt/master}"

die() {
  echo "Error: $*" >&2
  exit 1
}

info() {
  echo "$*"
}

main_lefthook_bin() {
  local repo="$1"
  local candidate
  for candidate in \
    "$repo/node_modules/.bin/lefthook" \
    "$repo/node_modules/lefthook/bin/index.js" \
    "$repo/node_modules/lefthook-$(uname | tr '[:upper:]' '[:lower:]')-$(uname -m | sed 's/aarch64/arm64/;s/x86_64/x64/')/bin/lefthook"; do
    [[ -x "$candidate" || -f "$candidate" ]] && {
      printf '%s\n' "$candidate"
      return 0
    }
  done
  return 1
}

git_wt() {
  local repo="$1"
  shift
  local lefthook_bin
  if lefthook_bin="$(main_lefthook_bin "$repo")"; then
    LEFTHOOK_BIN="$lefthook_bin" git "$@"
  else
    LEFTHOOK=0 git -c core.hooksPath=/dev/null "$@"
  fi
}

hook_strategy() {
  local repo="$1"
  local lefthook_bin
  if lefthook_bin="$(main_lefthook_bin "$repo")"; then
    printf 'using main checkout lefthook: %s\n' "$lefthook_bin"
  else
    printf 'disabled; no lefthook found in main checkout\n'
  fi
}

repo_root() {
  local common_dir
  common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || die "Run this command from inside a git repository."

  if [[ "$(basename "$common_dir")" == ".git" ]]; then
    dirname "$common_dir"
  else
    git rev-parse --show-toplevel 2>/dev/null || die "Run this command from inside a git repository."
  fi
}

default_base_ref() {
  local repo="$1"
  local remote_ref
  remote_ref="$(git -C "$repo" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"

  if [[ -n "$remote_ref" ]] && git -C "$repo" show-ref --verify --quiet "refs/remotes/$remote_ref"; then
    echo "$remote_ref"
  elif git -C "$repo" show-ref --verify --quiet refs/remotes/origin/master; then
    echo "origin/master"
  elif git -C "$repo" show-ref --verify --quiet refs/remotes/origin/main; then
    echo "origin/main"
  elif git -C "$repo" show-ref --verify --quiet refs/heads/master; then
    echo "master"
  elif git -C "$repo" show-ref --verify --quiet refs/heads/main; then
    echo "main"
  else
    echo "HEAD"
  fi
}

fresh_default_ref() {
  local repo="$1"
  local branch=""
  local remote_ref

  if git -C "$repo" remote get-url origin >/dev/null 2>&1; then
    remote_ref="$(git -C "$repo" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
    if [[ "$remote_ref" == origin/* ]]; then
      branch="${remote_ref#origin/}"
    elif git -C "$repo" show-ref --verify --quiet refs/remotes/origin/master; then
      branch="master"
    elif git -C "$repo" show-ref --verify --quiet refs/remotes/origin/main; then
      branch="main"
    fi

    if [[ -n "$branch" ]] &&
      git_wt "$repo" -C "$repo" fetch --prune origin "$branch" >/dev/null 2>&1 &&
      git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      echo "origin/$branch"
      return 0
    fi
  fi

  for branch in master main; do
    if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch"; then
      echo "$branch"
      return 0
    fi
  done

  die "Could not refresh origin default branch and local master/main does not exist."
}

pool_dir() {
  local repo="$1"
  if [[ -n "${WT_POOL_DIR:-}" ]]; then
    echo "$WT_POOL_DIR"
  else
    echo "$(dirname "$repo")/$(basename "$repo")-worktrees"
  fi
}

is_detached() {
  local wt="$1"
  ! git -C "$wt" symbolic-ref --quiet HEAD >/dev/null 2>&1
}

is_clean() {
  local wt="$1"
  [[ -z "$(git -C "$wt" status --porcelain)" ]]
}

branch_name() {
  local wt="$1"
  git -C "$wt" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "(detached HEAD)"
}

stat_mtime() {
  local path="$1"
  if stat -f %m "$path" >/dev/null 2>&1; then
    stat -f %m "$path"
  else
    stat -c %Y "$path"
  fi
}

format_mtime() {
  local epoch="$1"
  if date -r "$epoch" "+%Y-%m-%d %H:%M" >/dev/null 2>&1; then
    date -r "$epoch" "+%Y-%m-%d %H:%M"
  else
    date -d "@$epoch" "+%Y-%m-%d %H:%M"
  fi
}

wt_name() {
  local repo="$1"
  local wt="$2"
  if [[ "$wt" == "$repo" ]]; then
    echo "main"
  else
    basename "$wt"
  fi
}

relative_from_epoch() {
  local epoch="$1"
  local now diff value unit
  now="$(date +%s)"
  diff=$((now - epoch))
  ((diff < 0)) && diff=0

  if ((diff < 10)); then
    echo "just now"
    return 0
  elif ((diff < 60)); then
    value=$diff
    unit="sec"
  elif ((diff < 3600)); then
    value=$((diff / 60))
    unit="min"
  elif ((diff < 86400)); then
    value=$((diff / 3600))
    unit="hour"
  elif ((diff < 604800)); then
    value=$((diff / 86400))
    unit="day"
  elif ((diff < 2592000)); then
    value=$((diff / 604800))
    unit="week"
  elif ((diff < 31536000)); then
    value=$((diff / 2592000))
    unit="month"
  else
    value=$((diff / 31536000))
    unit="year"
  fi

  if ((value == 1)); then
    echo "1 $unit ago"
  else
    echo "$value ${unit}s ago"
  fi
}

install_command_for() {
  local wt="$1"
  if [[ -f "$wt/yarn.lock" ]]; then
    command -v yarn >/dev/null 2>&1 && echo "yarn install"
  elif [[ -f "$wt/pnpm-lock.yaml" ]]; then
    command -v pnpm >/dev/null 2>&1 && echo "pnpm install"
  elif [[ -f "$wt/package-lock.json" ]]; then
    command -v npm >/dev/null 2>&1 && echo "npm install"
  fi
  return 0
}

lockfile_for() {
  local wt="$1"
  if [[ -f "$wt/yarn.lock" ]]; then
    echo "yarn.lock"
  elif [[ -f "$wt/pnpm-lock.yaml" ]]; then
    echo "pnpm-lock.yaml"
  elif [[ -f "$wt/package-lock.json" ]]; then
    echo "package-lock.json"
  fi
  return 0
}

fzf_command() {
  local fzf_cmd="${WT_FZF_COMMAND:-fzf}"
  command -v "$fzf_cmd" >/dev/null 2>&1 || die "fzf is required for interactive wt. Install with: brew install fzf"
  echo "$fzf_cmd"
}

download_file() {
  local url="$1"
  local dest="$2"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$dest" "$url"
  else
    die "curl or wget is required."
  fi
}

all_pool_worktrees() {
  local repo="$1"
  local pool="$2"
  all_worktrees "$repo" |
    while IFS= read -r d; do
      [[ "$d" == "$pool"/* ]] && printf '%s\n' "$d"
    done | sort
}

all_worktrees() {
  local repo="$1"
  git_wt "$repo" -C "$repo" worktree list --porcelain |
    awk '/^worktree /{print substr($0,10)}' |
    sort
}

is_free_slot_path() {
  local path="$1"
  [[ "$(basename "$path")" =~ ^${WT_FREE_PREFIX}[0-9]+$ ]]
}

next_free_slot_path() {
  local pool="$1"
  local n=1
  while :; do
    local candidate="$pool/${WT_FREE_PREFIX}${n}"
    [[ ! -e "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
    n=$((n + 1))
  done
}

pick_idle_free_slot() {
  local repo="$1"
  local pool="$2"
  local candidates=()
  local wt
  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    is_free_slot_path "$wt" || continue
    if is_detached "$wt" && is_clean "$wt"; then
      local num
      num="$(basename "$wt" | sed -E "s/^${WT_FREE_PREFIX}([0-9]+)$/\\1/")"
      candidates+=("$num|$wt")
    fi
  done < <(all_pool_worktrees "$repo" "$pool")

  ((${#candidates[@]} > 0)) || return 1
  printf '%s\n' "${candidates[@]}" | sort -t'|' -k1,1n | head -n1 | cut -d'|' -f2-
}

pick_worktree_target() {
  local repo="$1"
  local query="$2"
  local matches=()
  local wt

  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    local branch base name
    branch="$(branch_name "$wt")"
    base="$(basename "$wt")"
    name="$(wt_name "$repo" "$wt")"
    if [[ "$wt" == "$query" || "$branch" == *"$query"* || "$base" == *"$query"* || "$name" == *"$query"* || "$wt" == *"$query"* ]]; then
      matches+=("$wt|$branch|$name")
    fi
  done < <(all_worktrees "$repo")

  if ((${#matches[@]} == 1)); then
    printf '%s\n' "${matches[0]%%|*}"
    return 0
  fi

  if ((${#matches[@]} > 1)); then
    info "Ambiguous match for '$query':"
    local m
    for m in "${matches[@]}"; do
      local path rest branch name
      path="${m%%|*}"
      rest="${m#*|}"
      branch="${rest%%|*}"
      name="${rest##*|}"
      printf '  %s (%s)\n' "$name" "$branch"
    done
    return 2
  fi
  return 1
}

cmd_grow() {
  local repo="$1"
  shift
  local pool
  pool="$(pool_dir "$repo")"
  local base_ref
  base_ref="$(default_base_ref "$repo")"
  local size=1
  local warm=0

  while (($#)); do
    case "$1" in
      --size)
        shift
        [[ $# -gt 0 ]] || die "--size requires a value"
        size="$1"
        ;;
      --base)
        shift
        [[ $# -gt 0 ]] || die "--base requires a value"
        base_ref="$1"
        ;;
      --warm)
        warm=1
        ;;
      *)
        die "Unknown option for grow: $1"
        ;;
    esac
    shift
  done
  [[ "$size" =~ ^[0-9]+$ && "$size" -gt 0 ]] || die "--size must be a positive integer"

  mkdir -p "$pool"
  git -C "$repo" rev-parse --verify "${base_ref}^{commit}" >/dev/null 2>&1 || die "Base ref '$base_ref' does not exist."

  info "Growing worktree pool in: $pool"
  info "Base ref: $base_ref"
  info "Adding: $size"
  info "Git hooks: $(hook_strategy "$repo")"

  local i slot
  for ((i = 1; i <= size; i++)); do
    slot="$(next_free_slot_path "$pool")"
    info "  - $(basename "$slot"): creating detached worktree at $slot"
    git_wt "$repo" -C "$repo" worktree add -q --detach "$slot" "$base_ref"

    if ((warm)); then
      local install_cmd lockfile
      lockfile="$(lockfile_for "$slot")"
      install_cmd="$(install_command_for "$slot")"
      if [[ -z "$lockfile" ]]; then
        info "    deps: no supported lockfile found; skipping install"
        continue
      fi
      if [[ -z "$install_cmd" ]]; then
        info "    deps: found $lockfile, but matching package manager is not in PATH; skipping install"
        continue
      fi
      if [[ -d "$slot/node_modules" ]]; then
        info "    deps: node_modules already present; skipping $install_cmd"
      else
        info "    deps: running $install_cmd"
        (cd "$slot" && $install_cmd)
      fi
    fi
  done
}

cmd_list() {
  local repo="$1"
  shift
  while (($#)); do
    case "$1" in
      --full) ;; # kept for backward compatibility; list is always full now
      *) die "Unknown option for list: $1" ;;
    esac
    shift
  done

  local rows=()
  local wt
  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    local name status mtime mtime_h branch
    name="$(wt_name "$repo" "$wt")"
    branch="$(branch_name "$wt")"
    status="clean"
    [[ -n "$(git -C "$wt" status --porcelain)" ]] && status="dirty"
    mtime="$(stat_mtime "$wt")"
    mtime_h="$(relative_from_epoch "$mtime")"
    rows+=("$mtime|$name|$status|$mtime_h|$branch")
  done < <(all_worktrees "$repo")

  local name_w=4
  local branch_w=6
  local row line name branch
  for row in "${rows[@]}"; do
    line="${row#*|}"   # drop epoch
    name="${line%%|*}"
    if ((${#name} > name_w)); then
      name_w=${#name}
    fi
    line="${line#*|}"  # drop name
    line="${line#*|}"  # drop status
    line="${line#*|}"  # drop modified
    branch="${line%%|*}"
    if ((${#branch} > branch_w)); then
      branch_w=${#branch}
    fi
  done

  info "Git Worktrees for $(basename "$repo")"
  printf "%-${name_w}s  %-7s  %-16s  %-${branch_w}s\n" "NAME" "STATUS" "LAST MODIFIED" "BRANCH"

  local line
  while IFS= read -r line; do
    local name status mtime_h branch
    line="${line#*|}"            # drop epoch
    name="${line%%|*}"
    line="${line#*|}"
    status="${line%%|*}"
    line="${line#*|}"
    mtime_h="${line%%|*}"
    branch="${line#*|}"
    printf "%-${name_w}s  %-7s  %-16s  %-${branch_w}s\n" "$name" "$status" "$mtime_h" "$branch"
  done < <(printf '%s\n' "${rows[@]}" | sort -t'|' -k1,1nr)

  info "$((${#rows[@]})) worktrees total"
}

cmd_interactive() {
  local repo="$1"
  shift
  [[ $# -eq 0 ]] || die "Unknown option for interactive mode: $1"

  local fzf_cmd
  fzf_cmd="$(fzf_command)"

  local rows=()
  local wt
  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    local name status mtime mtime_h branch
    name="$(wt_name "$repo" "$wt")"
    branch="$(branch_name "$wt")"
    status="clean"
    [[ -n "$(git -C "$wt" status --porcelain)" ]] && status="dirty"
    mtime="$(stat_mtime "$wt")"
    mtime_h="$(relative_from_epoch "$mtime")"
    rows+=("$mtime|$name|$status|$mtime_h|$branch|$wt")
  done < <(all_worktrees "$repo")

  local name_w=16
  local branch_w=18
  local row line name branch
  for row in "${rows[@]}"; do
    line="${row#*|}"
    name="${line%%|*}"
    if ((${#name} > name_w)); then
      name_w=${#name}
    fi
    line="${line#*|}"
    line="${line#*|}"
    line="${line#*|}"
    branch="${line%%|*}"
    if ((${#branch} > branch_w)); then
      branch_w=${#branch}
    fi
  done

  while :; do
    local selection_raw selection_key selection
    selection_raw="$(
      {
        printf "%-${name_w}s  %-7s  %-16s  %-${branch_w}s\t%s\t%s\n" "NAME" "STATUS" "LAST MODIFIED" "BRANCH" "__NAME__" "__PATH__"
        printf '%s\n' "${rows[@]}" |
          sort -t'|' -k1,1nr |
          while IFS='|' read -r _mtime _name _status _mtime_h _branch _path; do
            printf "%-${name_w}s  %-7s  %-16s  %-${branch_w}s\t%s\t%s\n" "$_name" "$_status" "$_mtime_h" "$_branch" "$_name" "$_path"
          done
        printf "%-${name_w}s  %-7s  %-16s  %-${branch_w}s\t%s\t%s\n" "Add new worktree" "" "" "" "__WT_GROW__" "__WT_GROW__"
      } |
        "$fzf_cmd" \
          --height=80% \
          --reverse \
          --expect=backspace \
          --footer='Esc: exit  |  Backspace: exit' \
          --header-lines=1 \
          --delimiter=$'\t' \
          --with-nth=1 \
          --prompt='Choose worktree> '
    )" || return 0

    selection_key=""
    selection="$selection_raw"
    if [[ "$selection_raw" == "backspace" ]]; then
      return 0
    elif [[ "$selection_raw" == *$'\n'* ]]; then
      selection_key="${selection_raw%%$'\n'*}"
      selection="${selection_raw#*$'\n'}"
    fi
    [[ "$selection_key" == "backspace" ]] && return 0
    [[ -n "$selection" ]] || return 0

    local name path action action_raw action_key action_selection actions
    name="$(awk -F $'\t' '{ print $2 }' <<<"$selection")"
    path="$(awk -F $'\t' '{ print $3 }' <<<"$selection")"
    [[ -n "$path" ]] || die "Could not resolve selected worktree path."
    if [[ "$path" == "__WT_GROW__" ]]; then
      if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
        printf '__WT_GROW__\n'
      else
        cmd_grow "$repo"
      fi
      return 0
    fi

    actions="$(
      printf '%s\t%-18s    \033[2m%s\033[0m\n' "go" "go" "cd into this worktree"
      if [[ "$path" != "$repo" ]] && ! is_free_slot_path "$path"; then
        printf '%s\t%-18s    \033[2m%s\033[0m\n' "free" "free" "detach and return this worktree to the free pool"
        printf '%s\t%-18s    \033[2m%s\033[0m\n' "realloc" "realloc" "free this worktree and allocate another branch into it"
      fi
      if is_free_slot_path "$path"; then
        printf '%s\t%-18s    \033[2m%s\033[0m\n' "alloc" "alloc" "allocate a new/existing branch in this free worktree"
      fi
      if [[ "$path" != "$repo" ]]; then
        printf '%s\t%-18s    \033[2m%s\033[0m\n' "remove" "remove" "delete this worktree from the pool"
      fi
    )"

    action_raw="$(
      printf '%s\n' "$actions" |
        "$fzf_cmd" \
          --height=10 \
          --reverse \
          --ansi \
          --expect=backspace \
          --footer='Esc: exit  |  Backspace: back' \
          --header="Chosen worktree: $name"$'\n'"Choose action:" \
          --delimiter=$'\t' \
          --with-nth=2 \
          --prompt='> '
    )" || return 0

    action_key=""
    action_selection="$action_raw"
    if [[ "$action_raw" == "backspace" ]]; then
      continue
    elif [[ "$action_raw" == *$'\n'* ]]; then
      action_key="${action_raw%%$'\n'*}"
      action_selection="${action_raw#*$'\n'}"
    fi
    [[ "$action_key" == "backspace" ]] && continue
    action="$(awk -F $'\t' '{ print $1 }' <<<"$action_selection")"

    case "$action" in
      go)
        if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
          printf '__WT_GO__\t%s\n' "$path"
        else
          info "$path"
          info "Run: cd $path"
        fi
        ;;
      free)
        if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
          printf '__WT_FREE__\t%s\t%s\n' "$name" "$path"
        else
          die "Shell integration is not loaded. Run: source ~/.config/wt/wt.zsh"
        fi
        ;;
      realloc)
        if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
          printf '__WT_REALLOC__\t%s\t%s\n' "$name" "$path"
        else
          die "Shell integration is not loaded. Run: source ~/.config/wt/wt.zsh"
        fi
        ;;
      remove)
        if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
          printf '__WT_REMOVE__\t%s\t%s\n' "$name" "$path"
        else
          die "Shell integration is not loaded. Run: source ~/.config/wt/wt.zsh"
        fi
        ;;
      alloc)
        if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
          printf '__WT_ALLOC__\n'
        else
          cmd_alloc "$repo"
        fi
        ;;
      "")
        return 0
        ;;
      *)
        die "Unknown action: $action"
        ;;
    esac
    return 0
  done
}

cmd_go() {
  local repo="$1"
  shift
  local print_path=0
  local query=""
  while (($#)); do
    case "$1" in
      --print-path) print_path=1 ;;
      *) query="$1" ;;
    esac
    shift
  done
  [[ -n "$query" ]] || die "Usage: wt go <query>"

  local matches=()
  local wt
  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    local branch base name
    branch="$(branch_name "$wt")"
    base="$(basename "$wt")"
    name="$(wt_name "$repo" "$wt")"
    if [[ "$branch" == *"$query"* || "$base" == *"$query"* || "$name" == *"$query"* || "$wt" == *"$query"* ]]; then
      matches+=("$wt|$branch|$name")
    fi
  done < <(all_worktrees "$repo")

  if ((${#matches[@]} == 1)); then
    local path="${matches[0]%%|*}"
    if ((print_path)); then
      printf '%s\n' "$path"
    else
      info "$path"
      info "Run: cd $path"
    fi
    return 0
  fi

  if ((${#matches[@]} > 1)); then
    info "Ambiguous match for '$query'. Did you mean:"
    local m
    for m in "${matches[@]}"; do
      local path rest branch name
      path="${m%%|*}"
      rest="${m#*|}"
      branch="${rest%%|*}"
      name="${rest##*|}"
      printf '  %s (%s)\n' "$name" "$branch"
    done
    return 2
  fi

  info "No worktree matching '$query'"
  return 1
}

alloc_branch() {
  local repo="$1"
  local pool="$2"
  local branch="$3"
  local base_ref="$4"
  local base_overridden="$5"
  local preferred_slot="${6:-}"

  [[ -n "$branch" ]] || die "Branch name is required. Usage: wt alloc <branch>"
  info "Alloc requested for branch: $branch"
  info "Pool: $pool"
  info "Git hooks: $(hook_strategy "$repo")"

  local branch_exists=0
  if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch"; then
    branch_exists=1
  fi
  if ((branch_exists == 1)); then
    info "Branch mode: existing local branch"
  else
    info "Branch mode: new local branch"
  fi

  if ((branch_exists == 1)); then
    local existing_wt
    while IFS= read -r existing_wt; do
      [[ -n "$existing_wt" ]] || continue
      if [[ "$(branch_name "$existing_wt")" == "$branch" ]]; then
        die "Branch '$branch' is already checked out at: $existing_wt"
      fi
    done < <(all_worktrees "$repo")
  fi

  local rebase_ref="$base_ref"
  if ((base_overridden == 0)); then
    info "Refreshing remote default branch..."
    rebase_ref="$(fresh_default_ref "$repo")"
    info "Remote default branch ref: $rebase_ref"
    if ((branch_exists == 0)); then
      base_ref="$rebase_ref"
    fi
  else
    info "Base override: $base_ref"
  fi

  if ((branch_exists == 0 || base_overridden == 1)); then
    git -C "$repo" rev-parse --verify "${base_ref}^{commit}" >/dev/null 2>&1 || die "Base ref '$base_ref' does not exist."
  fi

  local slot
  if [[ -n "$preferred_slot" ]]; then
    slot="$preferred_slot"
    info "Using reallocated slot: $(basename "$slot")"
    is_detached "$slot" || die "Reallocated slot is not detached: $slot"
    is_clean "$slot" || die "Reallocated slot is not clean: $slot"
  else
    info "Looking for a clean detached free-N slot..."
    slot="$(pick_idle_free_slot "$repo" "$pool")" || die "No clean detached free slot available. Free one first."
    info "Using free slot: $(basename "$slot")"
  fi
  local old_head
  old_head="$(git -C "$slot" rev-parse --verify HEAD 2>/dev/null || true)"

  local target="$pool/$branch"
  [[ ! -e "$target" ]] || die "Target worktree path already exists: $target"
  mkdir -p "$(dirname "$target")"

  info "Moving worktree: $slot -> $target"
  git_wt "$repo" -C "$repo" worktree move "$slot" "$target"

  if ((branch_exists == 1)); then
    info "Checking out existing branch: $branch"
    git_wt "$repo" -C "$target" checkout --quiet "$branch"
    info "Rebasing on $rebase_ref..."
    (
      cd "$target"
      git_wt "$repo" rebase "$rebase_ref" --autostash
    )
  else
    info "Allocating branch $branch from $base_ref"
    git_wt "$repo" -C "$target" checkout --quiet -b "$branch" "$base_ref"
  fi

  local install_cmd lockfile
  install_cmd="$(install_command_for "$target")"
  lockfile="$(lockfile_for "$target")"
  local needs_install=0
  info "Checking dependencies..."
  if [[ -z "$lockfile" ]]; then
    info "No supported JS lockfile found; skipping dependency install."
  elif [[ -z "$install_cmd" ]]; then
    info "Found $lockfile, but matching package manager is not in PATH; skipping dependency install."
  elif [[ ! -d "$target/node_modules" ]]; then
    info "node_modules is missing; will run $install_cmd."
    needs_install=1
  elif [[ -n "$old_head" && -n "$lockfile" ]] && ! git -C "$target" diff --quiet "$old_head" HEAD -- "$lockfile" >/dev/null 2>&1; then
    info "$lockfile changed while reusing the slot; will run $install_cmd."
    needs_install=1
  else
    info "node_modules is present and lockfile did not change; skipping dependency install."
  fi

  if ((needs_install)); then
    info "Installing dependencies with $install_cmd..."
    (cd "$target" && $install_cmd)
  fi

  if ((branch_exists == 1)); then
    info "Checked out: $branch"
  else
    info "Allocated: $branch"
    info "Base:    $base_ref"
  fi
  info "Path:    $target"
  if [[ "${WT_SHELL_INTEGRATION:-0}" == "1" ]]; then
    printf '__WT_ALLOCATED__\t%s\n' "$target"
  fi
}

cmd_alloc() {
  local repo="$1"
  shift
  local pool
  pool="$(pool_dir "$repo")"
  mkdir -p "$pool"

  local base_ref
  base_ref="$(default_base_ref "$repo")"
  local base_overridden=0
  local branch=""

  while (($#)); do
    case "$1" in
      --base)
        shift
        [[ $# -gt 0 ]] || die "--base requires a value"
        base_ref="$1"
        base_overridden=1
        ;;
      *)
        if [[ -z "$branch" ]]; then
          branch="$1"
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
    shift
  done

  if [[ -z "$branch" ]]; then
    if [[ -t 0 ]]; then
      read -r -p "Branch name: " branch
    fi
  fi

  alloc_branch "$repo" "$pool" "$branch" "$base_ref" "$base_overridden" ""
}

cmd_realloc() {
  local repo="$1"
  shift
  local pool
  pool="$(pool_dir "$repo")"
  mkdir -p "$pool"

  local base_ref
  base_ref="$(default_base_ref "$repo")"
  local base_overridden=0
  local force=0
  local yes=0
  local query=""
  local branch=""

  while (($#)); do
    case "$1" in
      --base)
        shift
        [[ $# -gt 0 ]] || die "--base requires a value"
        base_ref="$1"
        base_overridden=1
        ;;
      --force) force=1 ;;
      --yes|-y) yes=1 ;;
      *)
        if [[ -z "$query" ]]; then
          query="$1"
        elif [[ -z "$branch" ]]; then
          branch="$1"
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
    shift
  done

  [[ -n "$query" ]] || die "Usage: wt realloc <worktree-query> [branch] [--base REF] [--force] [--yes]"
  if [[ -z "$branch" ]]; then
    if [[ -t 0 ]]; then
      read -r -p "Branch name: " branch
    fi
  fi
  [[ -n "$branch" ]] || die "Branch name is required. Usage: wt realloc <worktree-query> <branch>"

  info "Realloc requested for worktree: $query"
  info "Target branch: $branch"
  info "Pool: $pool"
  info "Git hooks: $(hook_strategy "$repo")"

  if [[ "$query" == "main" || "$query" == "$repo" ]]; then
    die "'main' is the primary checkout and cannot be reallocated."
  fi

  local target
  target="$(pick_worktree_target "$repo" "$query")" || die "No worktree matches '$query'"
  [[ "$target" != "$repo" ]] || die "'main' is the primary checkout and cannot be reallocated."
  if is_free_slot_path "$target"; then
    die "Worktree is already free. Use wt alloc <branch> instead."
  fi
  info "Resolved worktree: $target"

  info "Checking worktree status..."
  if [[ -n "$(git -C "$target" status --porcelain)" && "$force" -ne 1 ]]; then
    die "Worktree has uncommitted changes. Commit/stash first, or use --force."
  fi
  if [[ -n "$(git -C "$target" status --porcelain)" ]]; then
    info "Worktree is dirty; --force was provided."
  else
    info "Worktree is clean."
  fi

  if ((yes == 0)); then
    local answer
    if [[ -t 0 ]]; then
      read -r -p "Realloc $(basename "$target") ($target) to '$branch'? This detaches the current branch, moves/renames this worktree into the free pool, then renames it to the target branch. [y/N] " answer
      [[ "$answer" == [yY] || "$answer" == [yY][eE][sS] ]] || {
        info "Realloc cancelled."
        return 0
      }
    else
      die "Realloc requires confirmation. Re-run with --yes if intentional."
    fi
  fi

  if ! is_detached "$target"; then
    info "Detaching HEAD before reallocating this worktree."
    git_wt "$repo" -C "$target" checkout --quiet --detach
  else
    info "HEAD is already detached."
  fi

  local slot
  slot="$(next_free_slot_path "$pool")"
  info "Moving selected worktree to temporary free slot: $slot"
  git_wt "$repo" -C "$repo" worktree move "$target" "$slot"

  alloc_branch "$repo" "$pool" "$branch" "$base_ref" "$base_overridden" "$slot"
}

cmd_free() {
  local repo="$1"
  shift
  local pool
  pool="$(pool_dir "$repo")"
  mkdir -p "$pool"

  local force=0
  local query=""
  while (($#)); do
    case "$1" in
      --force) force=1 ;;
      *) query="$1" ;;
    esac
    shift
  done
  [[ -n "$query" ]] || die "Usage: wt free <branch|worktree-query> [--force]"
  info "Free requested for: $query"
  info "Pool: $pool"
  info "Git hooks: $(hook_strategy "$repo")"

  if [[ "$query" == "main" || "$query" == "$repo" ]]; then
    die "'main' is the primary checkout and is not part of the recyclable pool."
  fi

  local target
  target="$(pick_worktree_target "$repo" "$query")" || die "No worktree matches '$query'"
  info "Resolved worktree: $target"

  info "Checking worktree status..."
  if [[ -n "$(git -C "$target" status --porcelain)" && "$force" -ne 1 ]]; then
    die "Worktree has uncommitted changes. Commit/stash first, or use --force."
  fi
  if [[ -n "$(git -C "$target" status --porcelain)" ]]; then
    info "Worktree is dirty; --force was provided."
  else
    info "Worktree is clean."
  fi

  if ! is_detached "$target"; then
    info "Detaching HEAD before returning worktree to pool."
    git_wt "$repo" -C "$target" checkout --quiet --detach
  else
    info "HEAD is already detached."
  fi

  if is_free_slot_path "$target"; then
    info "Already free: $(basename "$target")"
    info "Path: $target"
    return 0
  fi

  local free_path
  free_path="$(next_free_slot_path "$pool")"
  if [[ "$target" != "$free_path" ]]; then
    info "Moving worktree to free slot: $free_path"
    git_wt "$repo" -C "$repo" worktree move "$target" "$free_path"
  fi

  info "Freed to: $(basename "$free_path")"
  info "Path: $free_path"
}

cmd_remove() {
  local repo="$1"
  shift

  local force=0
  local yes=0
  local query=""
  while (($#)); do
    case "$1" in
      --force) force=1 ;;
      --yes|-y) yes=1 ;;
      *) query="$1" ;;
    esac
    shift
  done
  [[ -n "$query" ]] || die "Usage: wt remove <branch|worktree-query> [--force] [--yes]"
  info "Remove requested for: $query"
  info "Git hooks: $(hook_strategy "$repo")"

  if [[ "$query" == "main" || "$query" == "$repo" ]]; then
    die "'main' is the primary checkout and cannot be removed by wt."
  fi

  local target
  target="$(pick_worktree_target "$repo" "$query")" || die "No worktree matches '$query'"
  info "Resolved worktree: $target"

  info "Checking worktree status..."
  if [[ -n "$(git -C "$target" status --porcelain)" && "$force" -ne 1 ]]; then
    die "Worktree has uncommitted changes. Commit/stash first, or use --force."
  fi
  if [[ -n "$(git -C "$target" status --porcelain)" ]]; then
    info "Worktree is dirty; --force was provided."
  else
    info "Worktree is clean."
  fi

  if ((yes == 0)); then
    local answer
    if [[ -t 0 ]]; then
      read -r -p "Remove $(basename "$target") ($target)? This deletes the worktree directory. [y/N] " answer
      [[ "$answer" == [yY] || "$answer" == [yY][eE][sS] ]] || {
        info "Remove cancelled."
        return 0
      }
    else
      die "Removal requires confirmation. Re-run with --yes if intentional."
    fi
  fi

  if ((force)); then
    info "Removing worktree with --force."
    git_wt "$repo" -C "$repo" worktree remove --force "$target"
  else
    info "Removing worktree."
    git_wt "$repo" -C "$repo" worktree remove "$target"
  fi
  info "Removed: $(basename "$target")"
  info "Path: $target"
}

cmd_update() {
  local tmp
  tmp="$(mktemp -t wt-install.XXXXXX)"

  info "Downloading installer from: $WT_REPO_RAW_BASE/install.sh"
  download_file "$WT_REPO_RAW_BASE/install.sh" "$tmp"
  bash "$tmp"
  rm -f "$tmp"
}

cmd_help() {
  cat <<'EOF'
wt - recycled git worktree pool helper

Usage:
  wt (interactive picker)
  wt grow [--size N] [--base REF] [--warm]
  wt alloc [branch] [--base REF]
  wt realloc <query> [branch] [--base REF] [--force] [--yes]
  wt go <query> [--print-path]
  wt list
  wt free <query> [--force]
  wt remove <query> [--force] [--yes]
  wt update

Behavior:
  - grow: adds new detached free-N slots to the reusable pool.
  - alloc: uses a free worktree for a new/existing branch (new starts at remote default).
  - realloc: frees a selected worktree, then allocates a branch into that same slot.
  - free: detaches HEAD and renames worktree to smallest available free-N.
  - remove: deletes a pool worktree after confirmation; main is protected.
  - update: downloads the latest installer from GitHub and reinstalls wt.
  - go: prints a path normally; with shell integration, changes directory.
EOF
}

main() {
  local cmd="${1:-interactive}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$cmd" in
    help|-h|--help) cmd_help; return 0 ;;
    update) cmd_update "$@"; return 0 ;;
  esac

  local repo
  repo="$(repo_root)"

  case "$cmd" in
    interactive) cmd_interactive "$repo" "$@" ;;
    grow) cmd_grow "$repo" "$@" ;;
    alloc) cmd_alloc "$repo" "$@" ;;
    realloc) cmd_realloc "$repo" "$@" ;;
    go) cmd_go "$repo" "$@" ;;
    list) cmd_list "$repo" "$@" ;;
    free) cmd_free "$repo" "$@" ;;
    remove) cmd_remove "$repo" "$@" ;;
    *) die "Unknown command: $cmd (run: wt help)" ;;
  esac
}

main "$@"
